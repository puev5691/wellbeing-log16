{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "log16 entity response card",
  "type": "object",
  "required": ["response_id", "request_id", "target_entity", "provider", "model", "response_text", "status"],
  "properties": {
    "response_id": {"type": "string"},
    "request_id": {"type": "string"},
    "target_entity": {"type": "string"},
    "provider": {"type": "string"},
    "model": {"type": "string"},
    "response_text": {"type": "string"},
    "raw_response_path": {"type": "string"},
    "error": {"type": ["string", "null"]},
    "status": {"type": "string", "enum": ["needs_review", "approved", "rejected", "failed"]},
    "created_at": {"type": "string"}
  }
}
